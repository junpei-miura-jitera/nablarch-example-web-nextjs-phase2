{
  "name": "nablarch-example-web-nextjs",
  "private": true,
  "packageManager": "pnpm@10.11.0",
  "scripts": {
    "dev": "pnpm --filter @app/web dev",
    "build": "pnpm --filter @app/web build",
    "test": "pnpm -r test",
    "typecheck": "pnpm -r typecheck",
    "lint": "pnpm --filter @app/web lint",
    "storybook": "pnpm --filter @app/storybook storybook",
    "dev:java": "cd _references/nablarch-example-web && mvn jetty:run"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}