{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "jsx": "preserve",
    "lib": ["dom", "dom.iterable", "esnext"],
    "noEmit": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      ":": ["./src"],
      ":/*": ["./src/*"]
    },
    "allowJs": true,
    "incremental": true
  },
  "include": ["**/*.ts", "**/*.tsx", ".next/types/**/*.ts"],
  "exclude": [
    "node_modules",
    ".next",
    "**/*.stories.ts",
    "**/*.stories.tsx",
    "next.config.ts",
    "playwright.config.ts",
    "vitest.config.ts"
  ]
}
